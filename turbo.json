{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "stream",
    "globalDependencies": [".env"],
    "globalEnv": ["REST_PORT", "DATABASE_URL", "ENC_KEY", "DOMAIN"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$"],
            "outputs": [".svelte-kit/**"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "migrate": {
            "cache": false
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
